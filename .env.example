# Read directly by the application (src/db/client.ts, drizzle.config.ts).
# In production this must be provided as a real environment variable / a
# server-side ".env" file — never committed, never uploaded by CI.
DATABASE_URL=mysql://sameview:sameview@localhost:3306/sameview

# Local Docker only (compose.yaml). Not read by the application itself —
# these configure the local MySQL container and are used to build the local
# DATABASE_URL above. Not relevant on the production server. MYSQL_USER /
# MYSQL_PASSWORD (or root / MYSQL_ROOT_PASSWORD) are also what you type into
# the local phpMyAdmin login form at http://localhost:8081 — phpMyAdmin has
# no separate credentials of its own.
MYSQL_DATABASE=sameview
MYSQL_USER=sameview
MYSQL_PASSWORD=sameview
MYSQL_ROOT_PASSWORD=root

# NODE_ENV, PORT and HOST are provided by the hosting platform at runtime
# (locally by Astro/Vite, on Netcup/Plesk by the Node.js application panel)
# and are intentionally not set here.
